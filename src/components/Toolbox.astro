---
const categories = [
  {
    title: "Backend & DB",
    icon: "database",
    skills: ["TypeScript", "Node.js", "PostgreSQL", "Supabase", "Drizzle"],
  },
  {
    title: "Frontend & UI",
    icon: "devices",
    skills: ["React", "Next.js", "Astro", "Tailwind CSS"],
  },
  {
    title: "Herramientas & Flujo",
    icon: "terminal",
    skills: ["Linux", "Docker", "Git", "IA Aplicada como acelerador"],
  },
];
---

<section class="mb-16" id="toolbox" aria-label="Caja de herramientas y dominio técnico">
  <div class="bg-surface-container rounded-xl p-8 md:p-12 scroll-reveal-card">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xs uppercase tracking-[0.2em] font-bold text-on-surface-variant">
        Caja de herramientas & Dominio técnico
      </h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {categories.map((cat) => (
        <div class="bg-surface-container-low p-6 rounded-lg border border-outline/10 hover:border-outline/30 transition-colors">
          <div class="flex items-center gap-3 mb-4 text-primary">
            <span class="material-symbols-outlined text-2xl" aria-hidden="true">{cat.icon}</span>
            <h3 class="font-bold text-base tracking-tight">{cat.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span class="bg-surface-container-high text-primary px-3 py-1.5 rounded-md text-xs font-mono font-medium">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
