---

<footer
  class="w-full py-12 px-6 mt-auto bg-stone-50 dark:bg-zinc-950 border-t border-surface-container"
  aria-label="Pie de página"
>
  <div
    class="flex flex-col md:flex-row justify-between items-center gap-6 max-w-7xl mx-auto"
  >
    <p class="text-zinc-700 dark:text-zinc-300 text-sm font-medium">
      © {new Date().getFullYear()} Joaquín Ossandón. Todos los derechos reservados.
    </p>
    <div class="flex gap-8">
      <a
        class="text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300 underline underline-offset-4 text-[10px] uppercase tracking-widest font-extrabold"
        href="mailto:hola@joaquin.com"
        aria-label="Enviar correo a Joaquín"
        >Email</a
      >
      <a
        class="text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300 underline underline-offset-4 text-[10px] uppercase tracking-widest font-extrabold"
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Perfil de LinkedIn (se abre en nueva pestaña)"
        >LinkedIn</a
      >
      <a
        class="text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all duration-300 underline underline-offset-4 text-[10px] uppercase tracking-widest font-extrabold"
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Perfil de GitHub (se abre en nueva pestaña)"
        >GitHub</a
      >
    </div>
  </div>
</footer>
