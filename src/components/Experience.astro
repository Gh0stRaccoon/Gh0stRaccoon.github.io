---
const experiences = [
  {
    role: "Docencia, Mentoría y Formación de Talento TI",
    company: "Posiciona, Desafío Latam, Edutecno & Awakelab",
    period: "Abr 2021 – Presente",
    description:
      "En paralelo a mi carrera como desarrollador, mantengo un fuerte compromiso con la educación tecnológica. Actualmente me desempeño como docente en OTEC Posiciona para el programa Talento Digital, rol que he complementado a lo largo de los años siendo profesor en Edutecno, docente en el área privada de Awakelab y mentor técnico en Desafío Latam. Mi enfoque en estos espacios es estructurar procesos de aprendizaje complejos, auditar arquitecturas web y ayudar a los estudiantes a depurar su código, lo que me ha otorgado una capacidad analítica profunda para leer, evaluar y mejorar sistemas desarrollados por terceros.",
    tags: ["Docencia TI", "Mentoría Técnica", "Auditoría Web", "Code Review"],
  },
  {
    role: "Inmersión Corporativa y Desarrollo Mobile",
    company: "Softserve - Proyecto Expedia",
    period: "May 2025 – Oct 2025",
    description:
      "Participé como Trainee en un entorno corporativo internacional de alto tráfico, enfocándome en el desarrollo móvil con Kotlin. Mi trabajo consistió en el análisis, depuración y resolución de incidencias en la interfaz de usuario y la lógica del cliente nativo. Además, adquirí experiencia directa en la integración de APIs GraphQL para la sincronización de datos y en la gestión del ciclo de vida del software operando con Jira bajo estrictos estándares de calidad.",
    tags: ["Kotlin", "Android Native", "GraphQL", "Jira", "Mobile Dev"],
  },
  {
    role: "Desarrollo Frontend y Ecosistema Ágil",
    company: "ComeS",
    period: "Ene 2022 – Feb 2024",
    description:
      "Durante más de dos años, fui responsable de la construcción y el mantenimiento de interfaces web dinámicas utilizando React, NextJS y el ecosistema JavaScript. Mi día a día se centró en la integración continua del cliente con el backend mediante el consumo de APIs RESTful y GraphQL, asegurando una experiencia de usuario fluida. Trabajé inmerso en un entorno de desarrollo iterativo bajo metodologías ágiles (Scrum), enfocado en la entrega constante de valor y nuevas funcionalidades.",
    tags: ["React", "Next.js", "JavaScript", "RESTful APIs", "GraphQL", "Scrum"],
  },
];
---

<section class="mb-20" id="experiencia" aria-label="Experiencia Profesional">
  <h2
    class="text-xs uppercase tracking-[0.2em] font-bold text-on-surface-variant mb-10 px-2 scroll-reveal-title"
  >
    Experiencia Profesional
  </h2>

  <div class="relative border-l border-outline/20 pl-6 md:pl-10 space-y-12 ml-2 md:ml-4">
    {
      experiences.map((exp) => (
        <article class="relative scroll-reveal-card group">
          <!-- Timeline dot -->
          <div
            class="absolute -left-[31px] md:-left-[47px] top-1.5 w-3.5 h-3.5 rounded-full bg-secondary ring-4 ring-background transition-transform duration-200 group-hover:scale-125"
            aria-hidden="true"
          />

          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-start">
            <!-- Left Info: Role, Company, Date -->
            <div class="md:col-span-5">
              <h3 class="text-lg md:text-xl font-black text-primary tracking-tight leading-snug">
                {exp.role}
              </h3>
              <div class="text-sm font-bold text-on-surface-variant mt-1">
                {exp.company}
              </div>
              <div class="text-xs font-mono font-medium text-on-surface-variant/70 mt-2">
                {exp.period}
              </div>
            </div>

            <!-- Right Info: Description & Tags -->
            <div class="md:col-span-7">
              <p class="text-on-surface-variant text-sm md:text-base leading-relaxed font-body">
                {exp.description}
              </p>

              <div class="flex flex-wrap gap-2 mt-4">
                {exp.tags.map((tag) => (
                  <span class="bg-surface-container-high text-primary px-2.5 py-1 rounded text-xs font-mono font-medium">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
